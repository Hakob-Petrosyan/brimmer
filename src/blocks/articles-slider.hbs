<section class="width-container page-section">
    <div class="section-top u-flex u-justify-between u-gap-8">
        <h2>{{title}}</h2>
        <p class="text-m color__concrete">{{subtitle}}</p>
    </div>
    <div class="slider-container">

        <div class="w-100 u-overflowHidden u-relative"
             id="articles__slider"
             data-slider-group-item="articles__slider"

             data-slides-view="3"
             data-slides-view-tablet="2"
             data-slides-view-mobile="1"

             data-space-between="16"
             data-space-between-tablet="12"
             data-space-between-mobile="8"

             data-pagination = 'false'
             data-pagination-tablet = 'false'
             data-pagination-mobile="false"
             data-pagination-clickable="false"

             data-grab-cursor='true'
             data-slides-loop="false"
             data-auto-play="false"
             data-slides-speed="1000"

        >
            <div class="swiper-wrapper">
                <div class="swiper-slide">
                    <div class="blog-card">
                        <div class="blog-card__image imgWrapper">
                            <img src="/assets/images/card-images/image-1.webp" alt="blog image">
                        </div>
                        <div class="blog-card__content u-flex u-flex-col">
                            <div class="u-flex u-flex-col u-gap-6">
                                <span class="text_S color__coal">Январь 2024</span>
                                <h3>Тренды в дизайне гостиных</h3>
                            </div>

                            <a href="" class="blog-card__action text-b-M">
