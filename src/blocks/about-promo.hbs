                    data-popup-set-title = 'НУЖНА ПРОФЕССИОНАЛЬНАЯ КОНСУЛЬТАЦИЯ ПО ПРОЕКТУ?'
                    data-popup-set-subtitle = 'Проведём консультацию, разберём задачи и ограничения, предложим оптимальные решения и следующий шаг к реализации.'
                    data-popup-set-button-text = 'Получить консультацию'
            >
                Начать изменения
